name: {{ cookiecutter.project_name }}

services:
  proxy:
    image: nginx:{{ cookiecutter._nginx_version }}
    ports:
      - 80:80
    volumes:
      - ./docker-compose.nginx.conf:/etc/nginx/conf.d/default.conf:ro
    restart: unless-stopped
    {%- if cookiecutter.include_frontend == 'y' %}
    depends_on:
      frontend:
        condition: service_started
      backend:
        condition: service_healthy
    {%- else %}
    depends_on:
      backend:
        condition: service_healthy
    {%- endif %}

  backend:
    env_file:
      - .env
    build:
      context: .
      dockerfile: Dockerfile.backend
    healthcheck:
      test: ["CMD-SHELL", "python -c \"import urllib.request; urllib.request.urlopen('http://127.0.0.1:8000/health')\" || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 15s
    restart: unless-stopped
    {%- if cookiecutter.include_database == 'y' %}
    depends_on:
      database:
        condition: service_healthy
    {%- endif -%}

{%- if cookiecutter.include_frontend == 'y' %}

  frontend:
    env_file:
      - .env
    build:
      context: .
      dockerfile: Dockerfile.frontend
    restart: unless-stopped
    depends_on:
      backend:
        condition: service_healthy
{%- endif -%}

{%- if cookiecutter.include_database == 'y' %}

  database:
    attach: false
    env_file:
      - .env
    environment:
      - POSTGRES_HOST_AUTH_METHOD=trust
    volumes:
      - postgres_data:/var/lib/postgresql
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres -h 127.0.0.1 || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s
    image: postgres:{{ cookiecutter._postgres_version }}
    restart: unless-stopped

volumes:
  postgres_data:
{%- endif -%}
