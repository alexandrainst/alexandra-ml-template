# Copy this file to `.env` and fill in the values. Never commit `.env`.

# Git identity used by `make setup-git` for local commits.
GIT_NAME=
GIT_EMAIL=
{%- if cookiecutter.include_frontend == 'y' %}

# Comma-separated list of origins allowed by the FastAPI CORS middleware.
CORS_ALLOW_ORIGINS=http://localhost:8000
{%- endif %}
